# Tarmak dev environment
# Copy this file to .env and adjust values as needed.

# Better Auth secret (generate a random string)
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# Credentials for `make agent` auto-login (must match an existing account)
TARMAK_EMAIL=you@example.com
TARMAK_PASSWORD=changeme

# --- Optional: production tuning ---

# CORS origins (comma-separated). Defaults to localhost:3000,localhost:4000
# TARMAK_ALLOWED_ORIGINS=https://tarmak.example.com

# Content Security Policy header. Defaults to a permissive localhost policy.
# TARMAK_CSP=default-src 'self'; script-src 'self'

# Session lifetime in days (default: 30)
# TARMAK_SESSION_DAYS=30

# Invite link lifetime in days (default: 7)
# TARMAK_INVITE_DAYS=7
