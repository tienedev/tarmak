{
  "name": "@tarmak/api",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "bin": {
    "tarmak": "./dist/index.js"
  },
  "files": ["dist/", "skills/", ".claude-plugin/"],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./trpc": {
      "types": "./src/trpc/router.ts"
    }
  },
  "scripts": {
    "prepack": "rm -rf skills .claude-plugin && cp -r ../../skills/skills skills && cp -r ../../.claude-plugin .claude-plugin",
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@inquirer/prompts": "^8.3.2",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@tarmak/db": "workspace:*",
    "@tarmak/kbf": "workspace:*",
    "@tarmak/shared": "workspace:*",
    "@trpc/server": "^11.1.0",
    "better-auth": "^1.2.0",
    "better-sqlite3": "^11.8.0",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.0",
    "pino": "^9.6.0",
    "uuid": "^11.0.0",
    "ws": "^8.20.0",
    "yjs": "^13.6.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.0.0",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "vitest": "^4.1.0"
  }
}
